const express = require("express");
const app = express();

// middleware básico
app.use(express.json());

// rota principal
app.get("/", (req, res) => {
  res.send("ROTA CRM BACKEND OK 🚀");
});

// rota teste
app.get("/teste", (req, res) => {
  res.json({ status: "ok" });
});

// porta obrigatória
const PORT = process.env.PORT || 3000;

// start server
app.listen(PORT, () => {
  console.log(`Servidor rodando na porta ${PORT}`);
});